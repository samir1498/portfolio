---
import Layout from "../../layouts/Layout.astro";
import { isRtl } from "../../i18n/ui";
const t = {
  title: "الصفحة غير موجودة",
  message: "هذه الصفحة غير موجودة.",
  link: "الصفحة الرئيسية",
};
---

<Layout title={t.title} description={t.message}>
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] gap-4 text-center"
    dir={isRtl("ar") ? "rtl" : "ltr"}
  >
    <h1 class="text-8xl font-bold text-primary">404</h1>
    <p class="text-xl text-muted">{t.message}</p>
    <a href="/ar/" class="text-primary hover:underline text-sm">{t.link}</a>
  </div>
</Layout>
