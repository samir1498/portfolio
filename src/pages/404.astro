---
import Layout from "../layouts/Layout.astro";
const t = {
  title: "Page Not Found",
  message: "This page doesn't exist.",
  link: "Go home",
};
---

<Layout title={t.title} description={t.message}>
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] gap-4 text-center"
  >
    <h1 class="text-8xl font-bold text-primary">404</h1>
    <p class="text-xl text-muted">{t.message}</p>
    <a href="/" class="text-primary hover:underline text-sm">{t.link}</a>
  </div>
</Layout>
