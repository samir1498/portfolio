---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const goals = [
  "Share real engineering experience and trade-offs.",
  "Document random side projects and recreational programming.",
  "Publish practical tool and workflow notes.",
  "Track my Java deep-dive progress publicly.",
];

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  }).format(date);
---

<Layout
  title="Blog | Samir Bettahar"
  description="Engineering notes, Java deep dives, random builds, and practical tool workflows."
>
  <section class="pt-28 pb-20">
    <div class="relative overflow-hidden rounded-3xl border border-border bg-page p-8 md:p-12">
      <div class="absolute -top-24 -right-20 w-72 h-72 bg-primary/15 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-32 -left-20 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>

      <div class="relative max-w-3xl">
        <p class="text-xs uppercase tracking-[0.24em] text-primary font-semibold">Samir's Blog</p>
        <h1 class="mt-3 text-4xl md:text-6xl font-bold tracking-tight text-foreground leading-[1.05]">
          Engineering Notes in Public
        </h1>
        <p class="mt-5 text-lg text-muted leading-relaxed">
          A focused log of things I build, break, learn, and improve, from Java deep dives to random project experiments.
        </p>
      </div>
    </div>

    <section class="mt-8 grid sm:grid-cols-2 gap-4">
      {goals.map((goal, idx) => (
        <article class="rounded-xl border border-border bg-secondary/40 p-5 hover:border-primary/50 transition-colors">
          <p class="text-xs font-semibold tracking-wider text-primary">Goal {idx + 1}</p>
          <p class="mt-2 text-secondary-foreground leading-relaxed">{goal}</p>
        </article>
      ))}
    </section>

    <section class="mt-10">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground">Posts</h2>
        <span class="text-sm text-muted">{posts.length} published</span>
      </div>

      <div class="mt-5 grid gap-4">
        {posts.map((post) => (
          <article class="group rounded-2xl border border-border bg-page p-6 md:p-7 hover:border-primary/60 hover:-translate-y-0.5 transition-all">
            <p class="text-sm text-muted">{formatDate(post.data.pubDate)}</p>
            <h3 class="mt-2 text-xl md:text-2xl font-semibold text-foreground leading-tight">
              <a href={`/blog/${post.slug}/`} class="hover:text-primary transition-colors">{post.data.title}</a>
            </h3>
            <p class="mt-3 text-muted leading-relaxed">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <ul class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <li class="px-2.5 py-1 rounded-full text-xs font-medium bg-secondary border border-border text-secondary-foreground">
                    {tag}
                  </li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </section>
  </section>
</Layout>
