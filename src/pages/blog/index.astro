---
import Layout from "@/layouts/Layout.astro";
import BlogList from "@/components/BlogList";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Get all unique tags
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

// Prepare data for React component (serialize if necessary, though Astro handles simple objects well)
const serializedPosts = posts.map((post) => ({
    slug: post.slug,
    data: {
        title: post.data.title,
        description: post.data.description,
        pubDate: post.data.pubDate,
        tags: post.data.tags,
    },
}));
---

<Layout
    title="Blog | Samir Bettahar"
    description="Engineering notes, Java deep dives, random builds, and practical tool workflows."
    ogImage="/og/blog-index.png"
    ogImageAlt="Samir Bettahar blog index preview image"
    fullWidth={true}
>
    <div class="relative min-h-screen w-full overflow-hidden pb-20 pt-32">
        {/* Atmospheric Background Orbs */}
        <div
            class="absolute inset-0 -z-10 h-full w-full bg-page overflow-hidden"
        >
            {/* Top Right Orb */}
            <div
                class="absolute -right-20 -top-20 h-[500px] w-[500px] rounded-full bg-primary/20 blur-[120px] opacity-30 animate-pulse"
                style="animation-duration: 8s;"
            >
            </div>

            {/* Bottom Left Orb */}
            <div
                class="absolute -left-20 bottom-0 h-[400px] w-[400px] rounded-full bg-primary/10 blur-[100px] opacity-20"
            >
            </div>

            {/* Center faint glow */}
            <div
                class="absolute left-1/2 top-1/3 -translate-x-1/2 h-[300px] w-[300px] rounded-full bg-primary/5 blur-[80px]"
            >
            </div>
        </div>

        <div class="container mx-auto px-4 md:px-6 relative z-10">
            {/* Hero Section */}
            <div class="mx-auto max-w-4xl text-center">
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary/50 border border-border/50 text-muted text-xs font-medium mb-6 backdrop-blur-md"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-primary"
                        ></span>
                    </span>
                    Engineering Log
                </div>

                <h1
                    class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl"
                >
                    Thinking in <span class="text-primary">Public</span>
                </h1>
                <p
                    class="mt-6 text-lg text-muted md:text-xl max-w-2xl mx-auto leading-relaxed"
                >
                    A collection of technical deep dives, random experiments,
                    and notes on software engineering.
                </p>

                {/* React Blog List Component */}
                <BlogList
                    client:load
                    initialPosts={serializedPosts}
                    allTags={allTags}
                />
            </div>
        </div>
    </div>
</Layout>
