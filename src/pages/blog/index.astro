---
import Layout from "@/layouts/Layout.astro";
import BlogList from "@/components/BlogList";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const estimateReadingTime = (text: string) => {
    const wordCount = text.trim().split(/\s+/).filter(Boolean).length;
    return Math.max(1, Math.ceil(wordCount / 220));
};

// Get all unique tags
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

// Prepare data for React component (serialize if necessary, though Astro handles simple objects well)
const serializedPosts = posts.map((post) => ({
    slug: post.slug,
    data: {
        title: post.data.title,
        description: post.data.description,
        pubDate: post.data.pubDate,
        tags: post.data.tags,
        readingTime: estimateReadingTime(post.body),
    },
}));
---

<Layout
    title="Blog | Samir Bettahar"
    description="Engineering notes, Java deep dives, random builds, and practical tool workflows."
    ogImage="/og/blog-index.png"
    ogImageAlt="Samir Bettahar blog index preview image"
    fullWidth={true}
>
    <div class="min-h-screen w-full pb-20 pt-32">
        <div class="container mx-auto px-4 md:px-6">
            {/* Hero Section */}
            <div class="mx-auto max-w-4xl text-center">
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary border border-border text-muted text-xs font-medium mb-6"
                >
                    <span class="inline-flex rounded-full h-2 w-2 bg-primary"
                    ></span>
                    Engineering Log
                </div>

                <h1
                    class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl"
                >
                    Thinking in <span class="text-primary">Public</span>
                </h1>
                <p
                    class="mt-6 text-lg text-muted md:text-xl max-w-2xl mx-auto leading-relaxed"
                >
                    A collection of technical deep dives, random experiments,
                    and notes on software engineering.
                </p>

                {/* React Blog List Component */}
                <BlogList
                    client:load
                    initialPosts={serializedPosts}
                    allTags={allTags}
                />
            </div>
        </div>
    </div>
</Layout>
