---
import Layout from "@/layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { getSeriesContext, validateSeries } from "@/lib/blogSeries";
import { siteConfig } from "@/config/seo";

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ data }) => !data.draft);
    validateSeries(posts);
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
validateSeries(allPosts);
const seriesContext = getSeriesContext(allPosts, post.slug);
const { Content } = await post.render();
const ogImage = post.data.ogImage || "/og/default.png";
const ogImageAlt =
    post.data.ogImageAlt || `${post.data.title} social preview image`;
const readingTimeMinutes = Math.max(
    1,
    Math.ceil(post.body.trim().split(/\s+/).filter(Boolean).length / 220),
);

const formatDate = (date: Date) =>
    new Intl.DateTimeFormat("en", {
        year: "numeric",
        month: "long",
        day: "2-digit",
    }).format(date);

const seriesJsonLd = seriesContext
    ? {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          headline: post.data.title,
          datePublished: post.data.pubDate.toISOString(),
          dateModified: post.data.updatedDate
              ? new Date(post.data.updatedDate).toISOString()
              : undefined,
          url: `${siteConfig.siteUrl}/blog/${post.slug}/`,
          isPartOf: {
              "@type": "CreativeWorkSeries",
              name: seriesContext.seriesTitle,
          },
          position: seriesContext.seriesOrder,
      }
    : null;
---

<Layout
    title={post.data.title}
    description={post.data.description}
    ogType="article"
    ogImage={ogImage}
    ogImageAlt={ogImageAlt}
    publishedTime={post.data.pubDate}
    modifiedTime={post.data.updatedDate}
    articleTags={post.data.tags}
>
    <article class="pt-28 pb-20 max-w-3xl mx-auto">
        {seriesJsonLd && (
            <script type="application/ld+json">
                {JSON.stringify(seriesJsonLd)}
            </script>
        )}
        <a
            href="/blog/"
            class="inline-flex items-center text-sm font-medium text-primary hover:underline"
            >← Back to blog</a
        >

        <header class="mt-5">
            <p class="text-sm text-muted">
                {formatDate(post.data.pubDate)} • {readingTimeMinutes} min read
            </p>
            {
                seriesContext && (
                    <div class="mt-3 inline-flex items-center gap-2 rounded-full border border-border/70 bg-secondary/30 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-secondary-foreground/80">
                        <span>{seriesContext.seriesTitle}</span>
                        <span class="text-primary/80">
                            Part {seriesContext.seriesOrder}
                        </span>
                    </div>
                )
            }
            <h1
                class="mt-2 text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight"
            >
                {post.data.title}
            </h1>
            <p class="mt-4 text-base md:text-lg text-muted leading-relaxed">
                {post.data.description}
            </p>
            {
                post.data.tldr && (
                    <div class="mt-5 rounded-xl border border-border bg-page p-4 text-left">
                        <p class="text-xs font-semibold uppercase tracking-wide text-muted">
                            TL;DR
                        </p>
                        <p class="mt-2 text-sm leading-relaxed text-secondary-foreground">
                            {post.data.tldr}
                        </p>
                    </div>
                )
            }

            {
                post.data.tags.length > 0 && (
                    <ul class="mt-5 flex flex-wrap gap-2">
                        {post.data.tags.map((tag) => (
                            <li class="px-2.5 py-1 rounded-full text-xs font-medium bg-secondary/40 border border-border/70 text-secondary-foreground">
                                {tag}
                            </li>
                        ))}
                    </ul>
                )
            }

            {
                seriesContext && (
                    <div class="mt-6 rounded-xl border border-border bg-page p-5 text-left">
                        <p class="text-xs font-semibold uppercase tracking-wide text-muted">
                            Series
                        </p>
                        <ul class="mt-3 space-y-2">
                            {seriesContext.posts.map((entry) => (
                                <li>
                                    {entry.slug === post.slug ? (
                                        <span class="text-sm font-semibold text-primary">
                                            Part {entry.seriesOrder} · {entry.title}
                                        </span>
                                    ) : (
                                        <a
                                            href={`/blog/${entry.slug}/`}
                                            class="text-sm text-secondary-foreground hover:text-foreground"
                                        >
                                            Part {entry.seriesOrder} · {entry.title}
                                        </a>
                                    )}
                                </li>
                            ))}
                        </ul>

                        <div class="mt-4 flex flex-wrap gap-3">
                            {seriesContext.previous && (
                                <a
                                    href={`/blog/${seriesContext.previous.slug}/`}
                                    class="inline-flex items-center rounded-full border border-border/70 bg-secondary/30 px-3 py-1 text-xs font-semibold text-secondary-foreground hover:text-foreground"
                                >
                                    ← Previous
                                </a>
                            )}
                            {seriesContext.next && (
                                <a
                                    href={`/blog/${seriesContext.next.slug}/`}
                                    class="inline-flex items-center rounded-full border border-border/70 bg-secondary/30 px-3 py-1 text-xs font-semibold text-secondary-foreground hover:text-foreground"
                                >
                                    Next →
                                </a>
                            )}
                        </div>
                    </div>
                )
            }
        </header>

        <section
            class="mt-8 rounded-2xl border border-border/80 bg-secondary/20 p-6 md:p-8 text-base leading-8 text-secondary-foreground [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:leading-tight [&_h2]:text-foreground [&_h3]:mt-6 [&_h3]:mb-2 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-foreground [&_p]:mt-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-5 [&_li]:mt-2 [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-4 [&_strong]:font-bold [&_strong]:text-foreground"
        >
            <Content />
        </section>
    </article>
</Layout>
