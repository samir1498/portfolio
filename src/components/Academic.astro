---
import { EDUCATION, ACADEMIC_PROJECTS } from "../data";
import { GraduationCap, Code2, Database, Brain } from "lucide-react";

const getTechContent = (tech: string) => {
  const s = tech.toLowerCase();
  let slug = "";

  if (s.includes("java")) slug = "openjdk";
  if (s.includes("jee") || s.includes("java ee")) slug = "jakartaee";
  if (s.includes("tomcat")) slug = "apachetomcat";
  if (s.includes("glassfish")) slug = "eclipseglassfish";
  if (s.includes("python")) slug = "python";
  if (s.includes("scikit")) slug = "scikitlearn";
  if (s.includes("opencv")) slug = "opencv";
  if (s.includes("tkinter")) slug = "python"; // Built-in python
  if (s.includes("react")) slug = "react";
  if (s.includes("next")) slug = "nextdotjs";
  if (s.includes("node")) slug = "nodedotjs";

  if (slug) {
    return { type: 'icon', slug };
  }

  // Fallbacks
  if (s.includes("data") || s.includes("ontology"))
    return { type: 'component', Component: Database };
  if (s.includes("learning") || s.includes("ai"))
    return { type: 'component', Component: Brain };

  return { type: 'component', Component: Code2 };
};
---

<section id="academic" class="py-20 bg-slate-50 dark:bg-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Education -->
    <div class="mb-20">
      <div class="animate-fade-in-up">
        <div class="mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
            Education
          </h2>
          <div class="w-16 h-1.5 bg-primary"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {EDUCATION.map((edu, idx) => (
          <div
            class="animate-fade-in-up"
            style={`animation-delay: ${idx * 200}ms`}
          >
            <div class="h-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-8 rounded-lg relative overflow-hidden group hover:border-primary/30 transition-colors">
              <div class="absolute top-4 right-4 text-slate-200 dark:text-slate-800">
                <GraduationCap className="w-16 h-16 opacity-50" />
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 relative z-10">
                {edu.degree}
              </h3>
              <p class="text-primary font-medium mb-1 relative z-10">
                {edu.institution}
              </p>
              <div class="flex flex-wrap gap-4 text-sm text-slate-500 mb-6 relative z-10">
                <span>{edu.period}</span>
                <span>•</span>
                <span>{edu.location}</span>
              </div>
              <p class="text-slate-600 dark:text-slate-400 text-sm relative z-10 leading-relaxed">
                {edu.details}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Academic Projects -->
    <div>
      <div class="animate-fade-in-up">
        <div class="mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
            Academic Research
          </h2>
          <div class="w-16 h-1.5 bg-primary"></div>
          <p class="mt-4 text-slate-600 dark:text-slate-400">
            Selected research and major university projects.
          </p>
        </div>
      </div>

      <div class="space-y-8">
        {ACADEMIC_PROJECTS.map((project, idx) => (
          <div
            class="animate-fade-in-up"
            style={`animation-delay: ${idx * 200}ms`}
          >
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg p-6 md:p-8 hover:border-primary/30 transition-colors shadow-sm">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
                <div>
                  <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-1">
                    {project.title}
                  </h3>
                  <p class="text-slate-500 dark:text-slate-400 font-medium">
                    {project.subtitle}
                  </p>
                </div>
                <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-sm rounded border border-slate-200 dark:border-slate-700 h-fit whitespace-nowrap">
                  {project.year}
                </span>
              </div>

              <ul class="space-y-2 mb-6 md:ml-4">
                {project.description.map((desc) => (
                  <li class="flex items-start gap-3 text-slate-600 dark:text-slate-300 text-sm">
                    <span class="mt-2 w-1.5 h-1.5 bg-slate-300 dark:bg-slate-600 rounded-full flex-shrink-0"></span>
                    {desc}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2 pt-4 border-t border-slate-100 dark:border-slate-800 md:ml-4">
                {project.technologies.map((tech) => {
                  const content = getTechContent(tech);
                  const TechIcon = content.type === 'component' ? content.Component : null;
                  return (
                    <div
                      class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-50 dark:bg-slate-800 rounded text-xs text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700"
                    >
                      {content.type === 'icon' ? (
                        <img
                            src={`https://cdn.simpleicons.org/${content.slug}`}
                            alt={tech}
                            class="w-3 h-3"
                            loading="lazy"
                        />
                      ) : (
                        TechIcon && <TechIcon className="w-3 h-3 text-primary" />
                      )}
                      {tech}
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
