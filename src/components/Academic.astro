---
import { EDUCATION, ACADEMIC_PROJECTS } from "../data";
import { GraduationCap, Code2, Database, Brain } from "lucide-react";

const getTechContent = (tech: string) => {
  const s = tech.toLowerCase();
  let slug = "";

  if (s.includes("java")) slug = "openjdk";
  if (s.includes("jee") || s.includes("java ee")) slug = "jakartaee";
  if (s.includes("tomcat")) slug = "apachetomcat";
  if (s.includes("glassfish")) slug = "eclipseglassfish";
  if (s.includes("python")) slug = "python";
  if (s.includes("scikit")) slug = "scikitlearn";
  if (s.includes("opencv")) slug = "opencv";
  if (s.includes("tkinter")) slug = "python";
  if (s.includes("react")) slug = "react";
  if (s.includes("next")) slug = "nextdotjs";
  if (s.includes("node")) slug = "nodedotjs";

  if (slug) {
    return { type: "icon", slug };
  }

  if (s.includes("data") || s.includes("ontology"))
    return { type: "component", Component: Database };
  if (s.includes("learning") || s.includes("ai"))
    return { type: "component", Component: Brain };

  return { type: "component", Component: Code2 };
};
---

<section id="academic" class="py-20 bg-page">
  <!-- Education -->
  <div class="mb-20">
    <div class="animate-fade-in-up">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
          Education
        </h2>
        <div class="w-16 h-1.5 bg-primary"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        EDUCATION.map((edu, idx) => (
          <div
            class="animate-fade-in-up"
            style={`animation-delay: ${idx * 200}ms`}
          >
            <div class="h-full bg-page border border-border p-8 rounded-lg relative overflow-hidden group hover:border-primary/30 transition-colors">
              <div class="absolute top-4 right-4 text-muted/20">
                <GraduationCap className="w-16 h-16 opacity-50" />
              </div>
              <h3 class="text-xl font-bold text-foreground mb-2 relative z-10">
                {edu.degree}
              </h3>
              <p class="text-primary font-medium mb-1 relative z-10">
                {edu.institution}
              </p>
              <div class="flex flex-wrap gap-4 text-sm text-muted mb-6 relative z-10">
                <span>{edu.period}</span>
                <span>•</span>
                <span>{edu.location}</span>
              </div>
              <p class="text-muted text-sm relative z-10 leading-relaxed">
                {edu.details}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Academic Projects -->
  <div>
    <div class="animate-fade-in-up">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
          Academic Research
        </h2>
        <div class="w-16 h-1.5 bg-primary"></div>
        <p class="mt-4 text-muted">
          Selected research and major university projects.
        </p>
      </div>
    </div>

    <div class="space-y-8">
      {
        ACADEMIC_PROJECTS.map((project, idx) => (
          <div
            class="animate-fade-in-up"
            style={`animation-delay: ${idx * 200}ms`}
          >
            <div class="bg-page border border-border rounded-lg p-6 md:p-8 hover:border-primary/30 transition-colors shadow-sm">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
                <div>
                  <h3 class="text-xl font-bold text-foreground mb-1">
                    {project.title}
                  </h3>
                  <p class="text-muted font-medium">{project.subtitle}</p>
                </div>
                <span class="px-3 py-1 bg-page text-muted text-sm rounded border border-border h-fit whitespace-nowrap">
                  {project.year}
                </span>
              </div>

              <ul class="space-y-2 mb-6 md:ml-4">
                {project.description.map((desc) => (
                  <li class="flex items-start gap-3 text-muted text-sm">
                    <span class="mt-2 w-1.5 h-1.5 bg-muted rounded-full flex-shrink-0" />
                    {desc}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2 pt-4 border-t border-border md:ml-4">
                {project.technologies.map((tech) => {
                  const content = getTechContent(tech);
                  const TechIcon =
                    content.type === "component" ? content.Component : null;
                  return (
                    <div class="flex items-center gap-1.5 px-3 py-1.5 bg-page rounded text-xs text-muted border border-border">
                      {content.type === "icon" ? (
                        <img
                          src={`https://cdn.simpleicons.org/${content.slug}`}
                          alt={tech}
                          class="w-3 h-3"
                          loading="lazy"
                        />
                      ) : (
                        TechIcon && (
                          <TechIcon className="w-3 h-3 text-primary" />
                        )
                      )}
                      {tech}
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
