---
import { SKILLS } from "@/data";
import { Shield, Code2 } from "lucide-react";

const getSkillIcon = (skill: string) => {
  const s = skill.toLowerCase();
  let slug = "";

  if (s.includes("typescript")) slug = "typescript";
  else if (s.includes("javascript")) slug = "javascript";
  else if (s === "java") slug = "openjdk";
  else if (s.includes("go")) slug = "go";
  else if (s.includes("react")) slug = "react";
  else if (s.includes("next")) slug = "nextdotjs";
  else if (s.includes("astro")) slug = "astro";
  else if (s.includes("svelte")) slug = "svelte";
  else if (s.includes("tailwind")) slug = "tailwindcss";
  else if (s.includes("nest")) slug = "nestjs";
  else if (s.includes("fastify")) slug = "fastify";
  else if (s.includes("spring")) slug = "springboot";
  else if (s.includes("postgres")) slug = "postgresql";
  else if (s.includes("typeorm")) slug = "typeorm";
  else if (s.includes("flyway")) slug = "flyway";
  else if (s.includes("docker")) slug = "docker";
  else if (s.includes("graal")) slug = "graalvm";
  else if (s.includes("zitadel")) slug = "zitadel";
  else if (s.includes("clerk")) slug = "clerk";
  else if (s.includes("vitest")) slug = "vitest";
  else if (s.includes("testcontainers")) slug = "testcontainers";
  else if (s.includes("playwright")) slug = "playwright";
  else if (s.includes("prometheus")) slug = "prometheus";
  else if (s.includes("opentelemetry")) slug = "opentelemetry";

  if (slug) return slug;
  if (s.includes("auth")) return Shield;
  return Code2;
};
---

<section id="skills" class="py-20 bg-page border-y border-border">
  <div class="animate-fade-in-up">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
        Technical Arsenal
      </h2>
      <div class="w-16 h-1.5 bg-primary mx-auto"></div>
      <p class="mt-4 text-muted max-w-2xl mx-auto">
        A comprehensive toolset I use to build scalable, high-performance
        applications.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      SKILLS.map((category, idx) => (
        <div
          class="animate-fade-in-up"
          style={`animation-delay: ${idx * 100}ms;`}
        >
          <div class="h-full bg-page border border-border p-6 rounded-lg hover:border-primary/50 transition-colors duration-300 group shadow-sm hover:shadow-md">
            <div class="mb-4">
              <h3 class="text-lg font-bold text-foreground border-b border-border pb-2">
                {category.name}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => {
                const Icon = getSkillIcon(skill);
                return (
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-medium bg-page text-muted border border-border rounded transition-colors hover:border-primary group/pill">
                    {typeof Icon === "string" ? (
                      <img
                        src={`https://cdn.simpleicons.org/${Icon}`}
                        alt={skill}
                        class="w-3.5 h-3.5"
                        loading="lazy"
                      />
                    ) : (
                      <Icon className="w-3.5 h-3.5 text-muted" />
                    )}
                    {skill}
                  </span>
                );
              })}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
