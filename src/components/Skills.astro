---
import { SKILLS } from "@/data";
---

<section id="skills" class="py-20 bg-page border-y border-border">
  <div class="animate-fade-in-up">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
        Technical Arsenal
      </h2>
      <div class="w-16 h-1.5 bg-primary mx-auto"></div>
      <p class="mt-4 text-muted max-w-2xl mx-auto">
        A comprehensive toolset I use to build scalable, high-performance
        applications.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      SKILLS.map((category, idx) => (
        <div
          class="animate-fade-in-up"
          style={`animation-delay: ${idx * 100}ms;`}
        >
          <div class="h-full bg-page border border-border p-6 rounded-lg hover:border-primary/50 transition-colors duration-300 group shadow-sm hover:shadow-md">
            <div class="mb-4">
              <h3 class="text-lg font-bold text-foreground border-b border-border pb-2">
                {category.name}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-medium bg-page text-muted border border-border rounded transition-colors hover:border-primary">
                  <img
                    src={skill.icon}
                    alt={skill.name}
                    class="w-3.5 h-3.5 dark:invert dark:brightness-200"
                    loading="lazy"
                  />
                  {skill.name}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
