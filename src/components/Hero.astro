---
import { ArrowRight, ArrowLeft, Download } from "lucide-react";
import { Image } from "astro:assets";
import { getLocalizedData, type Lang } from "@/data";
import { PERSONAL_INFO as CONTACT_INFO } from "@/shared-data";
import profileImage from "@/assets/me.jpeg";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const { PERSONAL_INFO } = getLocalizedData(lang);
const cvReleaseUrls: Record<Lang, string> = {
    en: "https://github.com/samir1498/CV/releases/latest/download/Bettahar-Samir-Resume.pdf",
    fr: "https://github.com/samir1498/CV/releases/latest/download/Bettahar-Samir-CV.pdf",
    ar: "https://github.com/samir1498/CV/releases/latest/download/Bettahar-Samir-Ar-CV.pdf",
};
---

<section
    id="about"
    class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16 bg-page transition-colors duration-300"
>
    <div class="w-full relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Text Content -->
            <div>
                <div class="animate-fade-in-up" style="animation-delay: 100ms">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-medium mb-6"
                    >
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex rounded-full h-2 w-2 bg-primary"
                            ></span>
                        </span>
                        {PERSONAL_INFO.available}
                    </div>
                </div>

                <div class="animate-fade-in-up" style="animation-delay: 200ms">
                    <h1
                        class="text-5xl md:text-7xl font-bold tracking-tight text-foreground mb-6"
                    >
                        {
                            lang === "ar"
                                ? "مرحباً، أنا"
                                : lang === "fr"
                                  ? "Salut, je suis"
                                  : "Hi, I'm"
                        }
                        <br />
                        <span class="text-primary">{PERSONAL_INFO.name}</span>
                    </h1>
                </div>

                <div class="animate-fade-in-up" style="animation-delay: 300ms">
                    <h2 class="text-2xl md:text-3xl font-light text-muted mb-6">
                        {PERSONAL_INFO.title}
                    </h2>
                    <p class="text-lg text-muted leading-relaxed mb-8 max-w-lg">
                        {PERSONAL_INFO.summary}
                    </p>
                </div>

                <div
                    class="flex flex-wrap gap-4 animate-fade-in-up"
                    style="animation-delay: 400ms"
                >
                    <a
                        href="#contact"
                        class="group relative inline-flex items-center justify-center px-8 py-3 text-base font-medium text-primary-foreground bg-primary rounded-lg transition-all hover:opacity-90 active:scale-95"
                    >
                        {PERSONAL_INFO.contactMe}
                        {
                            lang === "ar" ? (
                                <ArrowLeft className="me-2 w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                            ) : (
                                <ArrowRight className="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" />
                            )
                        }
                    </a>
                    <a
                        href={cvReleaseUrls[lang]}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center px-8 py-3 text-base font-medium text-secondary-foreground bg-secondary border border-border rounded-lg hover:opacity-80 transition-all active:scale-95"
                    >
                        <Download className="rtl:ml-2 ltr:mr-2 w-4 h-4" />
                        {PERSONAL_INFO.downloadCV}
                    </a>
                </div>

                <div
                    class="mt-8 flex gap-6 animate-fade-in-up"
                    style="animation-delay: 500ms"
                >
                    <a
                        href={`https://github.com/${CONTACT_INFO.contact.github}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted hover:text-primary transition-colors"
                        aria-label="GitHub Profile"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href={`https://linkedin.com/in/${CONTACT_INFO.contact.linkedin}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted hover:text-primary transition-colors"
                        aria-label="LinkedIn Profile"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-6 h-6"
                        >
                            <path
                                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Profile Image -->
            <div class="flex justify-center lg:justify-end relative">
                <div class="animate-fade-in-left">
                    <div class="relative">
                        <div
                            class="absolute top-0 right-0 -mr-4 -mt-4 w-24 h-24 rounded-full border-2 border-border z-0 bg-primary/10"
                        >
                        </div>
                        <div
                            class="absolute bottom-0 left-0 -ml-4 -mb-4 w-32 h-32 rounded-full border-2 border-primary/20 z-0"
                        >
                        </div>

                        <div
                            class="relative w-64 h-64 md:w-80 md:h-80 lg:w-[26rem] lg:h-[26rem] rounded-full overflow-hidden border-[6px] border-secondary shadow-xl z-10 bg-secondary animate-float"
                        >
                            <Image
                                src={profileImage}
                                alt={PERSONAL_INFO.name}
                                class="w-full h-full object-cover"
                                loading="eager"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
