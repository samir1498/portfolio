---
import { getLocalizedData, type Lang } from "@/data";
import { getCollection } from "astro:content";
import { ArrowUpRight, Construction } from "lucide-react";
import { createTranslator, type Translations } from "@/i18n/translate";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { SECTIONS } = getLocalizedData(lang);

const projects = await getCollection("projects");

const statusTranslations: Translations<"in-development" | "live" | "archived"> =
  {
    "in-development": {
      en: "In Development",
      fr: "En développement",
      ar: "قيد التطوير",
    },
    live: { en: "Live", fr: "En ligne", ar: "مباشر" },
    archived: { en: "Archived", fr: "Archivé", ar: "مؤرشف" },
  };

const emptyStateTranslations: Translations<"loading" | "workInProgress"> = {
  loading: {
    en: "Projects Loading...",
    fr: "Projets en cours...",
    ar: "المشاريع قيد التحميل...",
  },
  workInProgress: { en: "Work in Progress", fr: "En cours", ar: "قيد التنفيذ" },
};

const t = createTranslator(statusTranslations, lang);
const te = createTranslator(emptyStateTranslations, lang);
---

<section id="showcase" class="py-24 bg-page border-t border-border">
  <div class="animate-fade-in-up">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-bold text-foreground mb-4">
        {SECTIONS.portfolio}
      </h2>
      <div class="w-16 h-1.5 bg-primary mx-auto"></div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto space-y-6">
    {
      projects.map((project, i) => (
        <a
          href={`/${lang}/projects/${project.slug}`}
          class="animate-fade-in-up block group"
          style={`animation-delay: ${200 + i * 100}ms;`}
        >
          <div class="flex items-start gap-6 p-6 rounded-xl border border-border bg-card hover:border-primary/50 transition-colors">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-xl font-semibold text-foreground group-hover:text-primary transition-colors">
                  {project.data.title}
                </h3>
                <span
                  class={`text-xs font-medium px-2 py-0.5 rounded-full ${
                    project.data.status === "in-development"
                      ? "bg-primary/10 text-primary"
                      : project.data.status === "live"
                        ? "bg-emerald-500/10 text-emerald-500 dark:bg-emerald-400/10 dark:text-emerald-400"
                        : "bg-secondary text-secondary-foreground"
                  }`}
                >
                  {t(project.data.status)}
                </span>
              </div>
              <p class="text-muted text-sm mb-3">{project.data.subtitle}</p>
              <div class="flex flex-wrap gap-2">
                {project.data.techStack.slice(0, 6).map((tech) => (
                  <span class="text-xs px-2 py-1 rounded-md bg-secondary text-secondary-foreground">
                    {tech}
                  </span>
                ))}
                {project.data.techStack.length > 6 && (
                  <span class="text-xs px-2 py-1 rounded-md bg-secondary text-secondary-foreground">
                    +{project.data.techStack.length - 6}
                  </span>
                )}
              </div>
            </div>
            <ArrowUpRight className="w-5 h-5 text-muted group-hover:text-primary transition-colors shrink-0 mt-1" />
          </div>
        </a>
      ))
    }

    {
      projects.length === 0 && (
        <div
          class="animate-fade-in-up relative w-full max-w-4xl mx-auto aspect-video rounded-xl overflow-hidden border-2 border-dashed border-border bg-page flex flex-col items-center justify-center text-center p-8"
          style="animation-delay: 200ms;"
        >
          <div class="p-6 rounded-full bg-primary/10 mb-6 text-primary">
            <Construction className="w-10 h-10" />
          </div>

          <h3 class="text-2xl font-bold text-foreground mb-4">
            {te("loading")}
          </h3>

          <p class="text-muted max-w-lg mx-auto mb-8 text-lg">
            {SECTIONS.portfolioSubtitle}
          </p>

          <div class="flex gap-2 items-center text-sm font-semibold text-primary bg-primary/10 px-4 py-2 rounded-full">
            <Construction className="w-4 h-4" />
            <span>{te("workInProgress")}</span>
          </div>
        </div>
      )
    }
  </div>
</section>
