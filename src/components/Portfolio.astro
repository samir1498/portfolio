---
import { Construction, Rocket } from "lucide-react";
import { getLocalizedData, type Lang } from "@/data";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { SECTIONS } = getLocalizedData(lang);
---

<section id="showcase" class="py-24 bg-page border-t border-border">
  <div class="animate-fade-in-up">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-bold text-foreground mb-4">
        {SECTIONS.portfolio}
      </h2>
      <div class="w-16 h-1.5 bg-primary mx-auto"></div>
    </div>
  </div>

  <div class="animate-fade-in-up" style="animation-delay: 200ms;">
    <div
      class="relative w-full max-w-4xl mx-auto aspect-video rounded-xl overflow-hidden border-2 border-dashed border-border bg-page flex flex-col items-center justify-center text-center p-8"
    >
      <div class="p-6 rounded-full bg-primary/10 mb-6 text-primary">
        <Rocket className="w-10 h-10" />
      </div>

      <h3 class="text-2xl font-bold text-foreground mb-4">
        {lang === "fr" ? "Projets en cours..." : "Projects Loading..."}
      </h3>

      <p class="text-muted max-w-lg mx-auto mb-8 text-lg">
        {SECTIONS.portfolioSubtitle}
      </p>

      <div
        class="flex gap-2 items-center text-sm font-semibold text-primary bg-primary/10 px-4 py-2 rounded-full"
      >
        <Construction className="w-4 h-4" />
        <span>{lang === "fr" ? "En cours" : "Work in Progress"}</span>
      </div>
    </div>
  </div>
</section>
