---
import { PERSONAL_INFO, SOCIAL_LINKS } from "@/shared-data";
import { Code2 } from "lucide-react";
---

<footer class="bg-page py-12 border-t border-border">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo/Name -->
      <!-- Logo/Name -->
      <a href="#" class="flex items-center gap-2 group">
        <div
          class="bg-primary/10 p-1.5 rounded-lg text-primary group-hover:bg-primary/20 transition-colors"
        >
          <Code2 className="w-6 h-6" />
        </div>
        <span class="text-xl font-bold text-foreground"> Samir.Dev </span>
      </a>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        {
          SOCIAL_LINKS.slice(0, 4).map((link) => {
            const Icon = link.icon;
            return (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 text-muted hover:text-primary transition-colors"
                aria-label={link.label}
              >
                <Icon />
              </a>
            );
          })
        }
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="mt-8 pt-6 border-t border-border text-center -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8"
    >
      <p class="text-muted text-sm">
        &copy; {new Date().getFullYear()}
        {PERSONAL_INFO.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
