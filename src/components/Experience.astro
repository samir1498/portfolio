---
import { EXPERIENCE } from "../data";
import { Calendar, MapPin } from "lucide-react";
---

<section id="experience" class="py-20 bg-white dark:bg-darker relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-fade-in-up">
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
          Professional Experience
        </h2>
        <div class="w-16 h-1.5 bg-primary"></div>
      </div>
    </div>

    <!-- Timeline Container -->
    <div class="relative border-l-2 border-slate-200 dark:border-slate-800 ml-3 md:ml-6 space-y-16">
      {EXPERIENCE.map((exp, idx) => (
        <div class="relative pl-8 md:pl-12">
          <div
            class="animate-fade-in-left"
            style={`animation-delay: ${idx * 200}ms`}
          >
            <!-- Timeline Dot -->
            <span class="absolute -left-[9px] top-6 w-4 h-4 rounded-full bg-white dark:bg-darker border-4 border-primary"></span>

            <div class="relative">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-xl font-bold text-slate-900 dark:text-white">
                    {exp.role}
                  </h3>
                  <div class="text-lg text-primary font-medium mt-1">
                    {exp.company}
                  </div>
                </div>
                <div class="flex flex-col sm:flex-row gap-3 text-sm text-slate-500 dark:text-slate-400">
                  <div class="flex items-center gap-1.5 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full">
                    <Calendar className="w-3.5 h-3.5" />
                    {exp.period}
                  </div>
                  <div class="flex items-center gap-1.5 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full">
                    <MapPin className="w-3.5 h-3.5" />
                    {exp.location}
                  </div>
                </div>
              </div>

              <div class="bg-slate-50 dark:bg-slate-900/50 p-6 rounded-lg border border-slate-100 dark:border-slate-800">
                <ul class="space-y-3">
                  {exp.description.map((item) => (
                    <li class="flex items-start gap-3 text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
                      <span class="mt-2 w-1.5 h-1.5 bg-primary rounded-full flex-shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
