---
import { getLocalizedData, type Lang } from "@/data";
import { Calendar, MapPin } from "lucide-react";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { EXPERIENCE, SECTIONS } = getLocalizedData(lang);
---

<section id="experience" class="py-20 bg-page">
  <div class="animate-fade-in-up">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
        {SECTIONS.experience}
      </h2>
      <div class="w-16 h-1.5 bg-primary"></div>
    </div>
  </div>

  <!-- Timeline Container -->
  <div class="relative border-l-2 border-border ml-3 md:ml-6 space-y-16">
    {EXPERIENCE.map((job, idx) => (
      <div class="relative pl-8 md:pl-12 animate-fade-in-up" style={`animation-delay: ${idx * 200}ms`}>
        <!-- Timeline Dot -->
        <span class="absolute -left-[9px] top-6 w-4 h-4 rounded-full bg-page border-4 border-primary z-10"></span>
        
        <div class="relative">
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-4">
            <div>
              <h3 class="text-xl font-bold text-foreground">
                {job.role}
              </h3>
              <div class="text-lg text-primary font-medium mt-1">{job.company}</div>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 text-sm text-muted">
              <div class="flex items-center gap-1.5 bg-page border border-border px-3 py-1 rounded-full">
                <Calendar className="w-3.5 h-3.5" />
                {job.period}
              </div>
              <div class="flex items-center gap-1.5 bg-page border border-border px-3 py-1 rounded-full">
                <MapPin className="w-3.5 h-3.5" />
                {job.location}
              </div>
            </div>
          </div>
          
          <div class="bg-page p-6 rounded-lg border border-border">
            <ul class="space-y-3">
              {job.description.map((item) => (
                <li class="flex items-start gap-3 text-muted text-sm leading-relaxed">
                  <span class="mt-2 w-1.5 h-1.5 bg-primary rounded-full flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
