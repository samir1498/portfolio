---
import "../styles/global.css";
import { SEO } from "astro-seo";
import Navbar from "../components/Navbar";
import { getLangFromUrl } from "../i18n/utils";
import { isRtl } from "../i18n/ui";
import { getSeoConfig, siteConfig } from "../config/seo";

const lang = getLangFromUrl(Astro.url);
const dir = isRtl(lang) ? "rtl" : "ltr";
const pathname = Astro.url.pathname;

interface Props {
  title?: string;
  description?: string;
  fullWidth?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  articleTags?: string[];
}

const {
  title,
  description,
  fullWidth = false,
  ogImage,
  ogImageAlt,
  ogType,
  publishedTime,
  modifiedTime,
  articleTags,
} = Astro.props;

const seoConfig = getSeoConfig({
  title,
  description,
  lang,
  pathname,
  ogImage,
  ogImageAlt,
  ogType,
  publishedTime,
  modifiedTime,
  articleTags,
});

const isBlogOrEnglishOnly =
  pathname.startsWith("/blog/") || pathname === "/blog";

const currentPrefix = pathname.match(/^\/([a-z]{2})\//)?.[1];

function hreflangUrl(targetLang: string): string | null {
  if (isBlogOrEnglishOnly) return null;
  if (targetLang === "en") {
    const stripped = currentPrefix
      ? pathname.replace(/^\/[a-z]{2}/, "")
      : pathname;
    return `${siteConfig.siteUrl}${stripped}`;
  }
  if (!currentPrefix) {
    return `${siteConfig.siteUrl}/${targetLang}${pathname === "/" ? "/" : pathname}`;
  }
  const replaced = pathname.replace(/^\/[a-z]{2}/, `/${targetLang}`);
  return `${siteConfig.siteUrl}${replaced}`;
}

const alternativeLangs = ["en", "fr", "ar"].filter((l) => l !== lang);
const hreflangLinks = alternativeLangs
  .map((l) => {
    const href = hreflangUrl(l);
    return href ? { href, lang: l } : null;
  })
  .filter((x): x is { href: string; lang: string } => x !== null);

const xDefaultHref = isBlogOrEnglishOnly
  ? null
  : currentPrefix
    ? `${siteConfig.siteUrl}${pathname.replace(/^\/[a-z]{2}/, "")}`
    : `${siteConfig.siteUrl}${pathname}`;
---

<!doctype html>
<html lang={lang} dir={dir} class="dark" style="overflow-x:hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Samir.Dev Blog RSS"
      href="/rss.xml"
    />
    const xDefaultHref = isBlogOrEnglishOnly ? null : currentPrefix ? `${
      siteConfig.siteUrl
    }</head
  >${pathname.replace(/^\/[a-z]{2}/, "")}` : `${siteConfig.siteUrl}${pathname}`;
  {
    xDefaultHref && (
      <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    )
  }
  {
    hreflangLinks.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))
  }
  <SEO {...seoConfig} />

  <!-- Theme initialization -->
  <script is:inline>
    if (
      localStorage.theme === "dark" ||
      (!("theme" in localStorage) &&
        window.matchMedia("(prefers-color-scheme: dark)").matches)
    ) {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  </script>

  <body
    class="bg-page text-foreground antialiased overflow-x-hidden transition-colors duration-300"
  >
    <Navbar client:load lang={lang} pathname={Astro.url.pathname} />
    <main
      class={fullWidth ? "w-full" : "max-w-6xl mx-auto px-4 sm:px-6 lg:px-8"}
    >
      <slot />
    </main>
    <script is:inline>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
            }
          });
        },
        { threshold: 0.1 },
      );

      document
        .querySelectorAll(".animate-fade-in-up, .animate-fade-in-left")
        .forEach((el) => {
          observer.observe(el);
        });
    </script>
  </body>
</html>
