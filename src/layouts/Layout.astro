---
import "../styles/global.css";
import { SEO } from "astro-seo";
import Navbar from "../components/Navbar";
import { getLangFromUrl } from "../i18n/utils";
import { isRtl } from "../i18n/ui";
import { getSeoConfig } from "../config/seo";

const lang = getLangFromUrl(Astro.url);
const dir = isRtl(lang) ? "rtl" : "ltr";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const seoConfig = getSeoConfig({
  title,
  description,
  lang,
  pathname: Astro.url.pathname,
});
---

<!doctype html>
<html lang={lang} dir={dir} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...seoConfig} />

    <!-- Theme initialization -->
    <script is:inline>
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="bg-page text-foreground antialiased overflow-x-hidden transition-colors duration-300"
  >
    <Navbar client:load lang={lang} />
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <script is:inline>
      // Intersection Observer for scroll-triggered animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
            }
          });
        },
        { threshold: 0.1 }
      );

      document
        .querySelectorAll(".animate-fade-in-up, .animate-fade-in-left")
        .forEach((el) => {
          observer.observe(el);
        });
    </script>
  </body>
</html>
