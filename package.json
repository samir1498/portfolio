{
  "name": "portfolio-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "sync:cv": "./scripts/sync-cv.sh",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "prepare": "husky",
    "audit:scan": "unlighthouse --output-path .unlighthouse --mobile --samples 3 --throttle --no-cache",
    "audit:ci": "unlighthouse-ci --output-path .unlighthouse-ci --mobile --samples 2 --throttle --no-cache --reporter jsonExpanded --budget 80",
    "audit:analyze": "bash scripts/analyze-unlighthouse.sh .unlighthouse-ci/ci-result.json .unlighthouse-ci/analysis",
    "audit:scan:dev": "pnpm run audit:scan --site http://localhost:4321",
    "audit:scan:prod": "pnpm run audit:scan --site https://samir-bettahar.dev",
    "audit:ci:dev": "pnpm run audit:ci --site http://localhost:4321",
    "audit:ci:prod": "pnpm run audit:ci --site https://samir-bettahar.dev",
    "audit:full:dev": "sh -c 'pnpm run audit:ci:dev || true; pnpm run audit:analyze'",
    "audit:full:prod": "sh -c 'pnpm run audit:ci:prod || true; pnpm run audit:analyze'"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "astro": "^5.18.0",
    "astro-seo": "^0.8.4",
    "lucide-react": "^0.532.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "unlighthouse": "^0.17.7"
  }
}
